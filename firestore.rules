rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Anyone can view profiles, but only the owner can edit
      allow read: if true;
      allow write: if isOwner(userId); 
    }


    match /doubts/{doubtId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
      // Author and admin can edit/delete doubts. Also allows answering updates (responsesCount increment)
      allow update: if isAuth();
      allow delete: if isAuth() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /answers/{answerId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
      // Needed for doubt authors picking answers
      allow update: if isAuth();
      allow delete: if isAuth() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /notifications/{notifId} {
      // Users can read own notifications
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // Anyone can create a notification to another user (e.g. answer alert)
      allow write: if isAuth();
    }

    match /reputationEvents/{eventId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if isAuth();
    }

    match /tests/{testId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /testAttempts/{attemptId} {
      // Users can only see their own test attempts
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // Users can only submit attempts for themselves
      allow write: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // Mentorship
    match /mentors/{mentorId} {
      allow read: if isAuth();
      allow write: if isOwner(mentorId) || isAdmin();
    }

    match /mentorSlots/{slotId} {
      allow read: if isAuth();
      allow write: if isAuth() && (
        (request.method == 'create' && request.resource.data.mentorId == request.auth.uid) ||
        (request.method == 'update' && resource.data.mentorId == request.auth.uid) ||
        (request.method == 'update' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isBooked'])) // Allow students to book
      );
    }

    match /bookings/{bookingId} {
      allow read: if isAuth() && (resource.data.studentId == request.auth.uid || resource.data.mentorId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuth() && (resource.data.studentId == request.auth.uid || resource.data.mentorId == request.auth.uid);
    }

    // Real-time Chat
    match /conversations/{conversationId} {
      allow read, write: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth();
    }
    
    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
    }

    // Productivity
    match /tasks/{taskId} {
      allow read, write: if isAuth() && (
        (request.method == 'create' && request.resource.data.userId == request.auth.uid) || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    match /aiProductivityLogs/{logId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // Reputation - Keep accessible for client side payout but restrict to owners
    match /reputationEvents/{eventId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }
  }
}

